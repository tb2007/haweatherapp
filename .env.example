# Home Assistant
HA_BASE_URL=http://hatb.ad.bpu.link:8123
HA_TOKEN=your_long_lived_access_token_here

# Auth — change these before deploying
APP_USERNAME=admin
APP_PASSWORD=changeme
JWT_SECRET=change_this_to_a_random_64_char_string

# Webcam — set RTSP_URL to enable; leave blank to disable the webcam panel
# go2rtc runs as a sidecar container and transcodes RTSP → HLS internally
# The RTSP URL never reaches the browser
RTSP_URL=rtsp://user:pass@camera-ip:554/stream
