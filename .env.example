# Home Assistant
HA_BASE_URL=http://hatb.ad.bpu.link:8123
HA_TOKEN=your_long_lived_access_token_here

# Auth — change these before deploying
APP_USERNAME=admin
APP_PASSWORD=changeme
JWT_SECRET=change_this_to_a_random_64_char_string

# Webcam
# WEBCAM_TYPE: hls | mjpeg | youtube | disabled
# For RTSP: use go2rtc add-on in HA to transcode RTSP → HLS, then set type=hls
# go2rtc HLS URL format: http://your-ha:1984/api/stream.m3u8?src=camera_name
WEBCAM_TYPE=disabled
WEBCAM_URL=
